{
  "name": "mail-gateway",
  "version": "0.1.0",
  "description": "AI-oriented local mail gateway",
  "type": "module",
  "main": "dist/lib.js",
  "module": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "mail-gateway-reader": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js",
      "default": "./dist/lib.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bun build src/main.ts src/lib.ts --outdir dist --target bun && tsc --emitDeclarationOnly",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/user/repo",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/repo"
  },
  "license": "MIT",
  "trustedDependencies": [],
  "devDependencies": {
    "@types/bun": "1.1.14",
    "typescript": "5.7.2",
    "prettier": "3.4.2"
  },
  "dependencies": {
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1"
  }
}
